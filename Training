def plot_training_progress(training_history, plots_dir, current_epoch):
    """
    Plot training progress and save to plots directory.
    
    Args:
        training_history: List of dicts with 'epoch', 'train_loss', 'val_loss'
        plots_dir: Directory to save plots
        current_epoch: Current epoch number
    """
    plots_dir = Path(plots_dir)
    plots_dir.mkdir(parents=True, exist_ok=True)
    
    epochs = [entry['epoch'] for entry in training_history]
    train_losses = [entry['train_loss'] for entry in training_history]
    val_losses = [entry['val_loss'] for entry in training_history]

    # --- Robust plotting: drop extreme outliers so plots stay readable ---
    train_np = np.array(train_losses, dtype=float)
    val_np = np.array(val_losses, dtype=float)

    # finite mask
    train_ok = np.isfinite(train_np)
    val_ok = np.isfinite(val_np)

    # robust threshold from percentiles (train 기준으로 outlier 컷)
    if train_ok.sum() >= 5:
        med = np.nanmedian(train_np[train_ok])
        p95 = np.nanpercentile(train_np[train_ok], 95)
        # med/p95
        cutoff = max(med * 20.0, p95 * 5.0)
    else:
        cutoff = np.inf

    train_plot = train_np.copy()
    val_plot = val_np.copy()

    train_plot[(~train_ok) | (train_plot > cutoff)] = np.nan
    val_plot[(~val_ok) | (val_plot > cutoff)] = np.nan
    
    # Create figure with 2 subplots
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 5))
    
    # Plot 1: Linear scale
    ax1.plot(epochs, train_plot, 'o-', label='Train Loss', linewidth=2, markersize=4, alpha=0.7)
    ax1.plot(epochs, val_plot, 's-', label='Val Loss', linewidth=2, markersize=4, alpha=0.7)
    ax1.set_xlabel('Epoch', fontsize=12)
    ax1.set_ylabel('Loss', fontsize=12)
    ax1.set_title(f'Training Progress (Epoch {current_epoch})', fontsize=14)
    ax1.legend(fontsize=11)
    ax1.grid(True, alpha=0.3)
    
    # Plot 2: Log scale
    # log plot
    train_log = train_plot.copy()
    val_log = val_plot.copy()
    train_log[train_log <= 0] = np.nan
    val_log[val_log <= 0] = np.nan

    ax2.semilogy(epochs, train_log, 'o-', label='Train Loss', linewidth=2, markersize=4, alpha=0.7)
    ax2.semilogy(epochs, val_log, 's-', label='Val Loss', linewidth=2, markersize=4, alpha=0.7)
    ax2.set_xlabel('Epoch', fontsize=12)
    ax2.set_ylabel('Loss (log scale)', fontsize=12)
    ax2.set_title(f'Training Progress - Log Scale (Epoch {current_epoch})', fontsize=14)
    ax2.legend(fontsize=11)
    ax2.grid(True, alpha=0.3)
    
    plt.tight_layout()
    
    # Save plot
    output_file = plots_dir / f'training_epoch_{current_epoch:04d}.png'
    plt.savefig(output_file, dpi=150, bbox_inches='tight')
    plt.close()
    
    print(f"  → Saved plot to {output_file}")


