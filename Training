    # Model arguments
    parser.add_argument('--hidden_dim', type=int, default=256, help='Hidden dimension')
    parser.add_argument('--n_interactions', type=int, default=4, help='Number of interaction layers')
    parser.add_argument('--condition_dim', type=int, default=128, help='Conditioning dimension')
    parser.add_argument('--cutoff', type=float, default=5.0, help='Cutoff distance for GoTenNet (Angstroms)')
    parser.add_argument('--max_neighbors', type=int, default=128, help='Max neighbors per atom (GoTenNet)')
    parser.add_argument('--use_gotennet', action='store_true', default=True, help='Use GoTenNet encoder')
    
    # Training arguments
    parser.add_argument('--epochs', type=int, default=200, help='Number of epochs')
    parser.add_argument('--batch_size', type=int, default=32, help='Batch size')
    parser.add_argument('--lr', type=float, default=3e-4, help='Learning rate')
    parser.add_argument('--min_lr', type=float, default=3e-5, help='Minimum LR for cosine annealing')
    parser.add_argument('--warmup_epochs', type=int, default=10, help='Linear warmup epochs')
    parser.add_argument('--weight_decay', type=float, default=1e-5, help='Weight decay')
    parser.add_argument('--num_workers', type=int, default=4, help='Number of data loading workers')
    parser.add_argument('--device', type=str, default='cuda:0', help='Device (cuda:0, cuda:1, cuda:2, cpu)')
    parser.add_argument('--energy_threshold', type=float, default=None, 
                       help='Filter structures by E_rel/atom (eV). E.g., 0.05 for low-energy structures only')
    
    # Logging arguments
    parser.add_argument('--use_tensorboard', action='store_true', help='Use TensorBoard for real-time plotting')
    parser.add_argument('--use_wandb', action='store_true', help='Use Weights & Biases logging')
    parser.add_argument('--wandb_project', type=str, default='nanoparticle-cfm', help='W&B project name')
    parser.add_argument('--resume', type=str, default=None, help='Path to checkpoint to resume from')
    parser.add_argument("--debug", action="store_true", help="Enable verbose debug prints")
    parser.add_argument('--debug_every', type=int, default=50, help='Print debug every N steps (only if --debug). 0 disables.')
    parser.add_argument('--spike_loss', type=float, default=50.0, help='Skip batch if loss > this threshold')
    
    args = parser.parse_args()
    
    # Setup device
    device = torch.device(args.device if torch.cuda.is_available() or 'cpu' in args.device else 'cpu')
    print(f"Using device: {device}")
    
    output_dir = Path(args.output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)
    
    # Load datasets
    print("\nLoading datasets...")
    data_dir = Path(args.data_dir)
    
    with open(data_dir / 'train_dataset.pkl', 'rb') as f:
        train_dataset = pickle.load(f)
    with open(data_dir / 'val_dataset.pkl', 'rb') as f:
        val_dataset = pickle.load(f)
    with open(data_dir / 'statistics.pkl', 'rb') as f:
        stats = pickle.load(f)
    
    print(f"Train: {len(train_dataset)} samples")
    print(f"Val:   {len(val_dataset)} samples")
    
    # ========== ENERGY FILTERING BASED ON E_rel/atom (SIMPLIFIED!) ==========
    if args.energy_threshold is not None:
        print(f"\n Filtering structures with E_rel/atom < {args.energy_threshold} eV...")
        
        def filter_by_e_rel(dataset, threshold):
            """Filter dataset by E_rel/atom threshold using data.y"""
            filtered = []
            skipped = 0
            
            for data in dataset:
                # data.y contains E_rel/atom (set during preprocessing)
                if hasattr(data, 'y') and data.y is not None:
                    e_rel_per_atom = data.y.item() if torch.is_tensor(data.y) else data.y
                    
                    if e_rel_per_atom < threshold:
                        filtered.append(data)
                    else:
                        skipped += 1
                else:
                    # No E_rel info, keep it
                    filtered.append(data)
            
            return filtered, skipped
        
        train_dataset_original = train_dataset
        val_dataset_original = val_dataset
        
        train_dataset, train_skipped = filter_by_e_rel(train_dataset, args.energy_threshold)
        val_dataset, val_skipped = filter_by_e_rel(val_dataset, args.energy_threshold)
        
        print(f"  Train: {len(train_dataset_original)} → {len(train_dataset)} samples "
              f"({100*len(train_dataset)/len(train_dataset_original):.1f}% kept, {train_skipped} filtered)")
        print(f"  Val:   {len(val_dataset_original)} → {len(val_dataset)} samples "
              f"({100*len(val_dataset)/len(val_dataset_original):.1f}% kept, {val_skipped} filtered)")
    # ======================================================================
    
    # Create dataloaders
    train_loader = DataLoader(
        train_dataset,
        batch_size=args.batch_size,
        shuffle=True,
        num_workers=args.num_workers,
    )
    val_loader = DataLoader(
        val_dataset,
        batch_size=args.batch_size,
        shuffle=False,
        num_workers=args.num_workers,
    )
    
    # Create model
    print("\nInitializing model...")
    model = NanoparticleCFM(
        hidden_dim=args.hidden_dim,
        n_interactions=args.n_interactions,
        condition_dim=args.condition_dim,
        cutoff=args.cutoff,
        max_neighbors=args.max_neighbors,
        use_gotennet=args.use_gotennet,
    ).to(device)
    
    print(f"Model parameters: {sum(p.numel() for p in model.parameters()):,}")
    model._print_encoder_debug = True
    model.debug = args.debug
    # Optimizer and scheduler
    optimizer = AdamW(
        model.parameters(),
        lr=args.lr,
        weight_decay=args.weight_decay,
    )

    # Warmup + Cosine Annealing scheduler
    # Phase 1: linear warmup from min_lr to lr over warmup_epochs
    # Phase 2: cosine decay from lr to min_lr over remaining epochs
    def lr_lambda(epoch):
        if epoch < args.warmup_epochs:
            return (args.min_lr + (args.lr - args.min_lr) * epoch / max(args.warmup_epochs, 1)) / args.lr
        progress = (epoch - args.warmup_epochs) / max(args.epochs - args.warmup_epochs, 1)
        cosine = 0.5 * (1 + np.cos(np.pi * progress))
        return (args.min_lr + (args.lr - args.min_lr) * cosine) / args.lr

    scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda)
    print(f"Scheduler: warmup {args.warmup_epochs} epochs → cosine decay to {args.min_lr:.1e}")
    
    # TensorBoard logging (ENABLED BY DEFAULT)
    writer = None
    if TENSORBOARD_AVAILABLE:
        tb_log_dir = output_dir / 'tensorboard'
        tb_log_dir.mkdir(parents=True, exist_ok=True)
        writer = SummaryWriter(log_dir=tb_log_dir)
        print(f"\n✅ TensorBoard logging enabled!")
        print(f"   Run in another terminal: tensorboard --logdir {tb_log_dir}")
        print(f"   Then open: http://localhost:6006\n")
    else:
        print("\n TensorBoard not available. Install with: pip install tensorboard\n")
    
    # Wandb logging
    if args.use_wandb:
        wandb.init(
            project=args.wandb_project,
            config=vars(args),
            name=f"cfm_{datetime.now().strftime('%Y%m%d_%H%M%S')}",
        )
    
    # Save hyperparameters to JSON
    import json
    hyperparams = {
        # Data
        'data_dir':         str(args.data_dir),
        'output_dir':       str(args.output_dir),
        # Model architecture
        'hidden_dim':       args.hidden_dim,
        'n_interactions':   args.n_interactions,
        'condition_dim':    args.condition_dim,
        'cutoff':           args.cutoff,
        'max_neighbors':    args.max_neighbors,
        'use_gotennet':     args.use_gotennet,
        # Training
        'epochs':           args.epochs,
        'batch_size':       args.batch_size,
        'lr':               args.lr,
        'min_lr':           args.min_lr,
        'warmup_epochs':    args.warmup_epochs,
        'weight_decay':     args.weight_decay,
        'energy_threshold': args.energy_threshold,
        'spike_loss':       args.spike_loss,
        # System
        'device':           str(device),
        'num_workers':      args.num_workers,
        'n_model_params':   sum(p.numel() for p in model.parameters()),
    }
    with open(output_dir / 'hyperparameters.json', 'w') as f:
        json.dump(hyperparams, f, indent=2)
    print(f"Saved hyperparameters → {output_dir / 'hyperparameters.json'}")

    # Training loop
    print("\n" + "="*80)
    print("TRAINING")
    print("="*80)
    
    best_val_loss = float('inf')
    training_history = []  # NEW: Store all losses
    start_epoch = 1

    # Resume from checkpoint if specified
    if args.resume:
        print(f"\nResuming from checkpoint: {args.resume}")
        ckpt = torch.load(args.resume, map_location=device, weights_only=False)
        model.load_state_dict(ckpt['model_state_dict'])
        optimizer.load_state_dict(ckpt['optimizer_state_dict'])
        if 'scheduler_state_dict' in ckpt:
            scheduler.load_state_dict(ckpt['scheduler_state_dict'])
        start_epoch = ckpt.get('epoch', 0) + 1
        best_val_loss = ckpt.get('val_loss', float('inf'))
        print(f"  Resumed from epoch {start_epoch - 1}  val_loss={best_val_loss:.4f}")

    for epoch in range(start_epoch, args.epochs + 1):
        # Train
        train_loss = train_epoch(
        model, train_loader, optimizer, device, epoch,
        debug=args.debug,
        debug_every=args.debug_every,
        spike_loss=args.spike_loss
    )
        
        # Validate
        val_loss = validate(model, val_loader, device)
        
        # Update scheduler
        if scheduler is not None:
            scheduler.step()
        
        # Log
        print(f"Epoch {epoch}/{args.epochs} - Train Loss: {train_loss:.4f} - Val Loss: {val_loss:.4f}")
        
        # NEW: Save to training history
        training_history.append({
            'epoch': epoch,
            'train_loss': float(train_loss),
            'val_loss': float(val_loss),
            'lr': optimizer.param_groups[0]['lr'],
        })
        
        # NEW: Save training history to JSON
        import json
        with open(output_dir / 'training_log.json', 'w') as f:
            json.dump(training_history, f, indent=2)
        
        # NEW: Plot losses every 50 epochs
        if epoch % 50 == 0 or epoch == 1:
            plot_training_progress(training_history, output_dir / 'plots', epoch)
        
        # TensorBoard logging (real-time!)
        if writer is not None:
            writer.add_scalar('Loss/train', train_loss, epoch)
            writer.add_scalar('Loss/val', val_loss, epoch)
            writer.add_scalar('Learning_rate', optimizer.param_groups[0]['lr'], epoch)
            writer.flush()  # Ensure data is written immediately
        
        if args.use_wandb:
            wandb.log({
                'epoch': epoch,
                'train_loss': train_loss,
                'val_loss': val_loss,
                'lr': optimizer.param_groups[0]['lr'],
            })
        
        # Save checkpoint
        if val_loss < best_val_loss:
            best_val_loss = val_loss
            checkpoint = {
                'epoch': epoch,
                'model_state_dict': model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'scheduler_state_dict': scheduler.state_dict(),
                'val_loss': val_loss,
                'args': vars(args),
                'stats': stats,
            }
            torch.save(checkpoint, output_dir / 'best_model.pt')
            print(f"  → Saved best model (val_loss: {val_loss:.4f}  lr: {optimizer.param_groups[0]['lr']:.2e})")
        
        # Save periodic checkpoint
        if epoch % 50 == 0:
            periodic_ckpt = {
                'epoch': epoch,
                'model_state_dict': model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'scheduler_state_dict': scheduler.state_dict(),
                'val_loss': val_loss,
                'args': vars(args),
                'stats': stats,
            }
            torch.save(periodic_ckpt, output_dir / f'model_epoch_{epoch}.pt')
    
    # Close TensorBoard writer
    if writer is not None:
        writer.close()
    
    print("\n" + "="*80)
    print("TRAINING COMPLETE!")
    print("="*80)
    print(f"Best validation loss: {best_val_loss:.4f}")
    print(f"Checkpoints saved to: {output_dir}")


if __name__ == '__main__':
    main()

